# App
APP_ENVIRONMENT=development
LOGGING_FILE_LEVEL=DEBUG
LOGGING_CONSOLE_LEVEL=DEBUG

# Database (use /app/data/production.db for Railway / Docker)
DB_PATH=data/development.db

# Bot (required)
BOT__TOKEN=your_bot_token_from_botfather
BOT__ADMIN_USER_ID=your_telegram_user_id

# Label Studio
LABEL_STUDIO_LOCAL_FILES_SERVING_ENABLED=true
LABEL_STUDIO_LOCAL_FILES_DOCUMENT_ROOT=/path/to/digitex
LABEL_STUDIO_API_KEY=your_label_studio_api_key_here

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key_here
