# ─── Environment ───────────────────────────────────────────
# Set ENVIRONMENT or APP_ENVIRONMENT to switch between env files
# APP_ENVIRONMENT=development
# APP_ENVIRONMENT=production

# ─── App ───────────────────────────────────────────────────
# APP_ENVIRONMENT=development
# LOGGING_FILE_LEVEL=DEBUG
# LOGGING_CONSOLE_LEVEL=INFO
# LOGGING_LOG_FILE=logs/app.log

# ─── Database (PostgreSQL) ─────────────────────────────────
# POSTGRES_PASSWORD is required — no default, Compose fails loudly if missing.
# Production: generate with `openssl rand -base64 24`
# POSTGRES_PASSWORD=your_strong_password
# DATABASE_URL is derived automatically by Compose from POSTGRES_PASSWORD.
# Override here only if your DB is not managed by this Compose file.
# DATABASE_URL=postgresql://digitex:your_strong_password@127.0.0.1:5433/digitex
# DB_POOL_MIN_SIZE=2
# DB_POOL_MAX_SIZE=10
# DB_POOL_TIMEOUT=10.0
# DB_STATEMENT_TIMEOUT_MS=5000
# DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=10000
# DB_SSLMODE=disable  # use 'require' or 'verify-full' in production

# ─── Bot (required for digitex-bot) ────────────────────────
# BOT_TOKEN=your_bot_token_from_botfather
# BOT_ADMIN_USER_ID=your_telegram_user_id

# ─── OpenRouter (for answer extraction) ────────────────────
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── Label Studio (optional) ───────────────────────────────
# LABEL_STUDIO_URL=http://localhost:8080
# LABEL_STUDIO_API_KEY=your_label_studio_api_key
# LABEL_STUDIO_LOCAL_FILES_SERVING_ENABLED=true
# LABEL_STUDIO_LOCAL_FILES_DOCUMENT_ROOT=C:/projects/digitex

# ─── Training (optional) ───────────────────────────────────
# DATA_IMAGE_SIZE=1280
# DATA_DATASET_DIR_NAME=dataset
# DATA_IMAGES_DIR_NAME=images
# TRAIN_RUNS_DIR_NAME=runs

# ─── Extraction (optional) ─────────────────────────────────
# EXTRACTION_QUESTION_MAX_WIDTH=2000
# EXTRACTION_QUESTION_MAX_HEIGHT=2000
# EXTRACTION_IMAGE_FORMAT=jpg

# ─── Timezone (optional) ───────────────────────────────────
# TIMEZONE_NAME=Europe/Minsk

# ─── Paths (optional) ──────────────────────────────────────
# PATH_ROOT_DIR=/path/to/project
